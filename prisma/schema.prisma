generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  username     String   @unique
  passwordHash String
  role         String   @default("user")
  onboarded    Boolean  @default(false)
  createdAt    DateTime @default(now())

  posts       Post[]
  categories  Category[]
  subscribers Subscriber[]
  settings    SiteSettings[]
}

model Post {
  id                Int       @id @default(autoincrement())
  userId            Int
  title             String
  slug              String
  content           String
  excerpt           String?
  coverImage        String?
  published         Boolean   @default(false)
  featured          Boolean   @default(false)
  readingTime       Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  publishedAt       DateTime?
  showUpdatedNotice Boolean   @default(false)
  views             Int       @default(0)

  user       User          @relation(fields: [userId], references: [id])
  categories PostCategory[]

  @@unique([userId, slug])
}

model Category {
  id          Int            @id @default(autoincrement())
  userId      Int
  name        String
  slug        String
  description String?
  color       String         @default("#2d7d9a")
  createdAt   DateTime       @default(now())

  user  User          @relation(fields: [userId], references: [id])
  posts PostCategory[]

  @@unique([userId, name])
  @@unique([userId, slug])
}

model PostCategory {
  postId     Int
  categoryId Int

  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
}

model SiteSettings {
  userId    Int
  key       String
  value     String
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@id([userId, key])
}

model Subscriber {
  id             Int       @id @default(autoincrement())
  userId         Int
  email          String
  name           String?
  token          String    @unique
  verified       Boolean   @default(false)
  lastSentAt     DateTime?
  createdAt      DateTime  @default(now())
  unsubscribedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, email])
}

model ManagerAuth {
  id           Int    @id @default(autoincrement())
  passwordHash String
}
